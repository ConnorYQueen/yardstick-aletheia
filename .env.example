# Copy this file to ".env" and fill in your own API key.
# The .env file stays on your machine; never commit it.

# --- Default provider: Anthropic (Claude) ---
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Optional: run on OpenAI instead (python aletheia.py --provider openai) ---
# OPENAI_API_KEY=

# --- Optional overrides ---
# ALETHEIA_PROVIDER=anthropic
# ALETHEIA_MODEL=claude-opus-4-8
